pragma solidity ^0.8.24;

import "@openzeppelin/contracts/token/ERC20/ERC20.sol";
import "@openzeppelin/contracts/token/ERC20/extensions/ERC20Burnable.sol";
import "@openzeppelin/contracts/token/ERC20/extensions/ERC20Pausable.sol";
import "@openzeppelin/contracts/token/ERC20/extensions/ERC20Permit.sol";
import "@openzeppelin/contracts/access/AccessControl.sol";
import "@openzeppelin/contracts/utils/Pausable.sol";

/// @title {{contractName}}
/// @notice ERC-20 token with optional mintable, burnable, pausable, and snapshot features
/// @dev Generated by ChainForge Engine
contract {{contractName}} is
    ERC20,
    AccessControl,
    ERC20Permit
    {{#if burnable}},
    ERC20Burnable{{/if}}
    {{#if pausable}},
    ERC20Pausable{{/if}}
{
    bytes32 public constant MINTER_ROLE = keccak256("MINTER_ROLE");
    bytes32 public constant PAUSER_ROLE = keccak256("PAUSER_ROLE");

    uint256 public maxSupply;

    /// @notice Emitted when tokens are minted
    event TokensMinted(address indexed to, uint256 amount);

    /// @notice Emitted when max supply is updated
    event MaxSupplyUpdated(uint256 oldSupply, uint256 newSupply);

    constructor(
        string memory name_,
        string memory symbol_
    ) ERC20(name_, symbol_) ERC20Permit(name_) {
        // Grant deployer the default admin, minter, and pauser roles
        _grantRole(DEFAULT_ADMIN_ROLE, msg.sender);
        {{#if mintable}}
        _grantRole(MINTER_ROLE, msg.sender);
        {{/if}}
        {{#if pausable}}
        _grantRole(PAUSER_ROLE, msg.sender);
        {{/if}}

        maxSupply = {{#if maxSupply}}{{maxSupply}} * 10 ** decimals(){{else}}1_000_000 * 10 ** decimals(){{/if}};
    }

    {{#if mintable}}
    /// @notice Mint new tokens to an address
    /// @param to The recipient address
    /// @param amount The amount to mint (in smallest unit)
    function mint(address to, uint256 amount) public onlyRole(MINTER_ROLE) {
        require(totalSupply() + amount <= maxSupply, "{{contractName}}: max supply exceeded");
        _mint(to, amount);
        emit TokensMinted(to, amount);
    }
    {{/if}}

    {{#if pausable}}
    /// @notice Pause all token transfers
    function pause() public onlyRole(PAUSER_ROLE) {
        _pause();
    }

    /// @notice Unpause all token transfers
    function unpause() public onlyRole(PAUSER_ROLE) {
        _unpause();
    }

    /// @dev Override to enforce pausability on transfers
    function _update(address from, address to, uint256 amount)
        internal
        override(ERC20, ERC20Pausable)
    {
        super._update(from, to, amount);
    }
    {{/if}}

    /// @notice Update the maximum token supply
    /// @param newMaxSupply The new maximum supply (in smallest unit)
    function setMaxSupply(uint256 newMaxSupply) public onlyRole(DEFAULT_ADMIN_ROLE) {
        require(newMaxSupply >= totalSupply(), "{{contractName}}: new max below current supply");
        uint256 oldMax = maxSupply;
        maxSupply = newMaxSupply;
        emit MaxSupplyUpdated(oldMax, newMaxSupply);
    }

    /// @notice Returns a human-readable summary of the token configuration
    function getTokenInfo()
        external
        view
        returns (
            string memory tokenName,
            string memory tokenSymbol,
            uint256 currentSupply,
            uint256 tokenMaxSupply,
            uint8 tokenDecimals
        )
    {
        return (
            name(),
            symbol(),
            totalSupply(),
            maxSupply,
            decimals()
        );
    }
}
